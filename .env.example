# Base URL aplikasi (mis. http://localhost:3000 saat development)
APP_BASE_URL=

# URI Supabase Transaction pooler (port 6543) — dipakai aplikasi saat runtime
DATABASE_URL=

# URI Supabase Session pooler/direct (port 5432) — hanya dipakai drizzle-kit CLI
DIRECT_DATABASE_URL=

# URL project Supabase (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key Supabase (aman untuk client)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key Supabase (server-only, jangan pernah diekspos ke client)
SUPABASE_SECRET_KEY=

# Nama bucket private untuk media soal
SUPABASE_MEDIA_BUCKET=ist-media

# Nama bucket private untuk laporan PDF
SUPABASE_REPORT_BUCKET=ist-reports

# Secret HMAC token sesi peserta (32+ random bytes base64, mis. `openssl rand -base64 32`)
SESSION_TOKEN_SECRET=

# Pepper hashing kode akses (32+ random bytes base64, mis. `openssl rand -base64 32`)
ACCESS_CODE_PEPPER=

# DSN error monitoring (opsional, kosongkan jika tidak dipakai)
ERROR_MONITORING_DSN=
