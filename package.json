{
  "name": "ist",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --import ./tests/helpers/alias-hooks.ts --test \"tests/**/*.test.ts\"",
    "db:generate": "dotenv -e .env.local -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -e .env -- drizzle-kit migrate",
    "db:seed": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/seed.ts",
    "db:unseed": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/unseed.ts",
    "db:patch-ge-norms": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/patch-ge-norm-rows.ts",
    "db:relabel": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/relabel-default-master-data.ts",
    "golden:generate": "node --experimental-strip-types scripts/generate-golden-cases.ts",
    "db:seed-e2e": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/seed-e2e.ts",
    "test:e2e": "dotenv -e .env.local -e .env -- playwright test",
    "create-admin": "dotenv -e .env.local -e .env -- node --experimental-strip-types scripts/create-admin-user.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.20.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
